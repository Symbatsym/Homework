class Student:
    def __init__(self, name, age, major):
        self.name = name
        self.age = age
        self.major = major
        self.courses = {}  

    def greet(self):
        print(f"Hello, my name is {self.name}. I study {self.major}.")

    def add_course(self, course, grade=None):
        self.courses[course] = grade
        print(f"Course '{course}' added with grade {grade}.")

    def update_grade(self, course, grade):
        if course in self.courses:
            self.courses[course] = grade
            print(f"Grade for '{course}' updated to {grade}.")
        else:
            print(f"Course '{course}' not found.")

    def show_courses(self):
        if not self.courses:
            print("No courses enrolled yet.")
            return
        print("Courses and grades:")
        for course, grade in self.courses.items():
            print(f" - {course}: {grade}")

    def calculate_gpa(self):
        if not self.courses:
            print("No courses to calculate GPA.")
            return 0
        grades = [grade for grade in self.courses.values() if grade is not None]
        if not grades:
            print("No graded courses to calculate GPA.")
            return 0
        gpa = sum(grades) / len(grades)
        print(f"Current GPA: {gpa:.2f}")
        return gpa

    def is_honor(self):
        gpa = self.calculate_gpa()
        if gpa >= 3.5:
            print("Student is an Honor student.")
        else:
            print("Student is not an Honor student.")

p1 = Student("Aida", 20, "Computer Science")
p1.greet()
p1.add_course("Math", 3.7)
p1.add_course("Physics", 3.4)
p1.add_course("English")  # без оценки пока
p1.show_courses()
p1.update_grade("English", 3.8)
p1.show_courses()
p1.calculate_gpa()
p1.is_honor()
